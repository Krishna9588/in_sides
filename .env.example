# Database Configuration
SUPABASE_URL=your_supabase_url_here
SUPABASE_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_KEY=your_supabase_service_key_here

# Redis Configuration
REDIS_URL=redis://localhost:6379
REDIS_CACHE_TTL=3600

# AI/ML Configuration
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-pro

# Local Models Configuration
SENTENCE_MODEL=sentence-transformers/all-MiniLM-L6-v2
CLASSIFICATION_MODEL=distilbert-base-uncased
GENERATION_MODEL=microsoft/DialoGPT-medium

# Apify Configuration
APIFY_TOKEN=your_apify_token_here

# Agent Configuration
AGENT_BATCH_SIZE=100
AGENT_MAX_RETRIES=3
AGENT_TIMEOUT=300

# Processing Configuration
SIMILARITY_THRESHOLD=0.7
CONFIDENCE_THRESHOLD=0.7
MIN_CLUSTER_SIZE=3
MAX_RETRIEVED_DOCS=10

# LLM Configuration
TEMPERATURE=0.7
MAX_TOKENS=2048
TOP_P=0.8
TOP_K=40

# Conversation Configuration
MAX_CONTEXT_LENGTH=4000
SESSION_TIMEOUT=3600
MAX_CONVERSATION_TURNS=50

# Security Configuration
SECRET_KEY=your-secret-key-change-in-production
CORS_ORIGINS=http://localhost:3000,https://yourapp.vercel.app

# Logging Configuration
LOG_LEVEL=INFO
LOG_FILE=/var/log/founder-intelligence.log

# App Configuration
DEBUG=false
APP_NAME=Founder Intelligence System
APP_VERSION=1.0.0
